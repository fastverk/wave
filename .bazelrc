common --enable_bzlmod
common --experimental_isolated_extension_usages

common --registry=https://registry.fastverk.com/
common --registry=https://bcr.bazel.build/

common --action_env=HOME

test --test_output=errors
test --test_summary=terse

try-import %workspace%/user.bazelrc

# ─── Go operator image ────────────────────────────────────────────
# //operator/cmd:wave-operator-image targets linux/amd64 (EKS) and its
# distroless-static base is amd64-only, so the IMAGE rule must build under a
# linux/amd64 platform regardless of host. The Go library/binary build fine on
# the host without this — only the image rule needs it:
#   bazel build //operator/cmd:wave-operator-image --config=operator-image
#   bazel run   //operator/cmd:wave-operator-image_push --config=operator-image -- --tag=$SHA
build:operator-image --platforms=@rules_go//go/toolchain:linux_amd64
